# ═══════════════════════════════════════════════════════════
#  MAC — MBM AI Cloud  |  Environment Configuration
# ═══════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────
MAC_ENV=development
MAC_HOST=0.0.0.0
MAC_PORT=8000
MAC_DEBUG=true
MAC_SECRET_KEY=change-me-to-a-random-64-char-string
MAC_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Database ──────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://mac:mac_password@localhost:5432/mac_db
# SQLite (development — no setup needed)
# DATABASE_URL=sqlite+aiosqlite:///./mac.db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LiteLLM Gateway ──────────────────────────────────────
# URL where LiteLLM proxy is running
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-mac-litellm-key

# ── Rate Limits ───────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_HOUR=100
RATE_LIMIT_TOKENS_PER_DAY=50000

# ── vLLM / OpenAI-compatible backend ──────────────────────
VLLM_BASE_URL=http://localhost:11434
